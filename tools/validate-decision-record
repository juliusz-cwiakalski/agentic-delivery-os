  Generated index tool: tools/generate-decision-index (regenerates doc/decisions/00-index.md)

EXIT CODES:
  0 - Success (all valid; heuristics may warn)
  1 - One or more hard validation failures
  2 - Usage error
  7 - Filesystem error
EOF
}

show_version() {
  cat <<EOF
${APP_NAME} ${APP_VERSION}
Copyright (c) 2025-2026 Juliusz Ćwiąkalski (https://www.cwiakalski.com | https://www.linkedin.com/in/juliusz-cwiakalski/ | https://x.com/cwiakalski)
MIT License - see LICENSE file for full terms
Latest version: https://github.com/juliusz-cwiakalski/agentic-delivery-os/blob/main/tools/${APP_NAME}
EOF
}

# Globals for accumulating findings
VALIDATION_ERRORS=()
VALIDATION_WARNS=()

parse_args() {
  SUMMARY_MODE=false
  LINT_MODE=false
  COVERAGE_MODE=false
  DRY_RUN=false
  ARGS=()
  while (($#)); do
    case "$1" in
      -h|--help) usage; exit 0 ;;
      -V|--version) show_version; exit 0 ;;
      -n|--dry-run) DRY_RUN=true ;;
      -v|--verbose) VERBOSE=true ;;
      --summary) SUMMARY_MODE=true ;;
      --lint) LINT_MODE=true ;;
      --coverage) COVERAGE_MODE=true ;;
      --) shift; while (($#)); do ARGS+=("$1"); shift; done ;;
      -*) die "Unknown option: $1 (see --help)" ;;
      *) ARGS+=("$1") ;;
    esac
    shift
  done
}

# Expand a path arg into the list of *.md files (records only) to validate
_expand_record_paths() {
  local -r p="$1"
  if [[ -f "$p" ]]; then
    printf '%s\n' "$p"
  elif [[ -d "$p" ]]; then
    find "$p" -maxdepth 1 -type f -name '*.md' ! -name '00-index.md' ! -name 'README.md' | sort
  fi
}

# ============================================================================
# MAIN
# ============================================================================
main() {
  parse_args "$@"

  require_cmd python3
  require_cmd jq
  require_cmd grep
  require_cmd awk

  if [[ "${COVERAGE_MODE}" == "true" ]]; then
    local repo_root
    repo_root="$(cd -- "${TOOLS_DIR}"/.. && pwd -P)"
    coverage_check "${repo_root}"
    if [[ "${COVERAGE_UNCOVERED}" -ne 0 ]]; then
      log_err "coverage check reports ${COVERAGE_UNCOVERED} uncovered schema rule(s)."
      exit "${EXIT_VALIDATION}"
    fi
    exit "${EXIT_SUCCESS}"
  fi

  if [[ ${#ARGS[@]} -eq 0 ]]; then
    die "No path provided. See --help."
  fi

  if [[ "${DRY_RUN}" == "true" ]]; then
    log_info "[DRY-RUN] Read-only validation (no files are ever written)."
  fi

  if [[ "${SUMMARY_MODE}" == "true" ]]; then
    local a
    for a in "${ARGS[@]}"; do
      validate_summary "$a"
    done
  else
    local a expanded
    for a in "${ARGS[@]}"; do
      if [[ -f "$a" ]]; then
        validate_record "$a" "${LINT_MODE}"
      elif [[ -d "$a" ]]; then
        while IFS= read -r f; do
          validate_record "$f" "${LINT_MODE}"
        done < <(_expand_record_paths "$a")
      else
        VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${a}: path not found.")
      fi
    done
  fi

  # Emit warnings to stderr (non-blocking)
  local w
  if [[ ${#VALIDATION_WARNS[@]} -gt 0 ]]; then
    for w in "${VALIDATION_WARNS[@]}"; do
      [[ -n "$w" ]] && printf '%s\n' "$w" >&2
    done
  fi

  # Emit errors to stderr (blocking)
  if [[ ${#VALIDATION_ERRORS[@]} -gt 0 ]]; then
    for w in "${VALIDATION_ERRORS[@]}"; do
      [[ -n "$w" ]] && printf '%s\n' "$w" >&2
    done
  fi

  if [[ ${#VALIDATION_ERRORS[@]} -gt 0 ]]; then
    printf '[ERROR] %s %d hard validation error(s).\n' "${LOG_TAG}" "${#VALIDATION_ERRORS[@]}" >&2
    exit "${EXIT_VALIDATION}"
  fi

  local nwarn=${#VALIDATION_WARNS[@]}
  if [[ "${DRY_RUN}" == "true" ]]; then
    printf '[INFO]  %s [DRY-RUN] validation passed (0 errors, %d heuristic warning(s)).\n' "${LOG_TAG}" "${nwarn}"
  else
    printf '[INFO]  %s validation passed (0 errors, %d heuristic warning(s)).\n' "${LOG_TAG}" "${nwarn}"
  fi
  exit "${EXIT_SUCCESS}"
}

# Testable main guard
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
