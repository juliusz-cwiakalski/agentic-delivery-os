# _record_id_from_json <json>
_record_id_from_json() { _jq -r '.id // empty' <<<"$1"; }

# join array into pipe-separated string
_join_pipe() {
  local -n _arr="$1"; local _out=""
  local _first=1
  for _v in "${_arr[@]}"; do
    if [[ $_first -eq 1 ]]; then _out="${_v}"; _first=0; else _out="${_out}|${_v}"; fi
  done
  printf '%s' "${_out}"
}

# validate_record <file> <lint_mode>  -> appends to global VALIDATION_ERRORS / VALIDATION_WARNS
validate_record() {
  local -r file="$1"
  local -r lint_mode="${2:-false}"
  local -r fname="$(basename -- "$file")"

  if [[ ! -f "$file" ]]; then
    VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname}: file not found.")
    return
  fi
  if ! _has_frontmatter "$file"; then
    VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname}: missing leading '---' front-matter fence.")
    return
  fi

  local json
  if ! json="$(_frontmatter_to_json "$file" 2>/dev/null)"; then
    VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname}: front matter failed to parse (unsupported YAML subset?).")
    return
  fi

  local id status dtype decision_date rigor
  id="$(_jq -r '.id // empty' <<<"$json")"
  status="$(_jq -r '.status // empty' <<<"$json")"
  dtype="$(_jq -r '.decision_type // empty' <<<"$json")"
  decision_date="$(_jq -r '.decision_date // empty' <<<"$json")"

  # --- required top-level fields ---
  local -a required_fields=(id decision_type status created decision_date last_updated summary service)
  local rf
  for rf in "${required_fields[@]}"; do
    if [[ "$(_jq -r --arg k "$rf" 'has($k)' <<<"$json")" == "false" ]]; then
      VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname} (id ${id:-<missing>}): required field '${rf}' is missing. Add it to the front matter (see doc/templates/decision-record-template.md).")
    fi
  done
  # owners: required + minItems 1
  if [[ "$(_jq -r 'has("owners")' <<<"$json")" == "false" ]]; then
    VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname} (id ${id:-<missing>}): required field 'owners' is missing (minItems: 1).")
  elif [[ "$(_jq -r '.owners | length' <<<"$json")" -lt 1 ]]; then
    VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname} (id ${id:-<missing>}): field 'owners' must have at least one entry (minItems: 1).")
  fi

  # --- decision_type enum ---
  local dt_re; dt_re="$(_join_pipe VALID_DECISION_TYPES)"
  if [[ -n "$dtype" ]] && [[ ! "$dtype" =~ ^($dt_re)$ ]]; then
    VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname} (id ${id:-<missing>}): field 'decision_type'='${dtype}' is not valid. Allowed: adr|pdr|tdr|bdr|odr.")
  fi

  # --- status enum ---
  local st_re; st_re="$(_join_pipe VALID_STATUSES)"
  if [[ -n "$status" ]] && [[ ! "$status" =~ ^($st_re)$ ]]; then
    VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname} (id ${id:-<missing>}): field 'status'='${status}' is not valid. Allowed: Proposed|Under Review|Accepted|Deprecated|Superseded.")
  fi

  # --- id pattern + filename match ---
  if [[ -n "$id" ]] && [[ ! "$id" =~ ^(ADR|PDR|TDR|BDR|ODR)-[0-9]{4}$ ]]; then
    VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname}: field 'id'='${id}' does not match <TYPE>-<zeroPad4> (e.g., ADR-0001).")
  fi
  if [[ -n "$id" ]]; then
    # filename stem should start with the id
    if [[ "$fname" != "${id}"* ]]; then
      VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname} (id ${id}): filename does not start with the id '${id}' (id must match filename stem).")
    fi
  fi

  # --- date formats (created, decision_date, last_updated, review_date) ---
  _check_date "$json" "$fname" "$id" "created"
  _check_date "$json" "$fname" "$id" "last_updated"
  _check_date "$json" "$fname" "$id" "review_date"

  # --- default rigor (DM-4): absent classification => R2 ---
  local has_classification
  has_classification="$(_jq -r 'has("classification")' <<<"$json")"
  if [[ "$has_classification" == "true" ]]; then
    rigor="$(_jq -r '.classification.rigor // empty' <<<"$json")"
    [[ -z "$rigor" ]] && rigor="R2"
  else
    rigor="R2"
    if [[ "$lint_mode" == "true" ]]; then
      VALIDATION_WARNS+=("[WARN] ${LOG_TAG} ${fname} (id ${id:-<missing>}): no 'classification' block; rigor defaulted to R2 (DM-4). Add a classification block when this record is next reviewed (non-destructive; not rewritten).")
    fi
  fi
  # rigor enum
  if [[ -n "$rigor" ]]; then
    local rg_re; rg_re="$(_join_pipe VALID_RIGORS)"
    if [[ ! "$rigor" =~ ^($rg_re)$ ]]; then
      VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname} (id ${id:-<missing>}): field 'classification.rigor'='${rigor}' is not valid. Allowed: R0|R1|R2|R3.")
    fi
  fi

  # --- rigor-aware / acceptance-gated required fields (DEC-12) ---
  if [[ "$status" == "Accepted" ]]; then
    # decision_date non-null
    if [[ -z "$decision_date" || "$decision_date" == "null" ]]; then
      VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname} (id ${id:-<missing>}): field 'decision_date' is required (non-null) when status=Accepted.")
    fi
    if [[ "$rigor" == "R2" || "$rigor" == "R3" ]]; then
      local decider
      decider="$(_jq -r '.governance.decider // empty' <<<"$json")"
      if [[ -z "$decider" || "$decider" == "null" ]]; then
        VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname} (id ${id:-<missing>}): field 'governance.decider' is required (non-null) when status=Accepted and rigor=${rigor}. Set the accountable authority.")
      fi
    fi
    if [[ "$rigor" == "R3" ]]; then
      local reviewers_len
      reviewers_len="$(_jq -r '.governance.reviewers | length' <<<"$json")"
      if [[ "${reviewers_len:-0}" -lt 1 ]]; then
        VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname} (id ${id:-<missing>}): field 'governance.reviewers' must be non-empty when status=Accepted and rigor=R3 (acceptance-gated per DEC-12).")
      fi
    fi
  fi

  # --- lifecycle / consistency (DM-5, single-snapshot) ---
  local superseded_by_len supersedes_len
  superseded_by_len="$(_jq -r '.links.superseded_by | length' <<<"$json")"
  supersedes_len="$(_jq -r '.links.supersedes | length' <<<"$json")"
  if [[ "$status" == "Superseded" ]]; then
    if [[ "${superseded_by_len:-0}" -lt 1 ]]; then
      VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname} (id ${id:-<missing>}): status 'Superseded' requires a non-empty 'links.superseded_by' referencing the replacing record.")
    fi
  fi
  if [[ "$status" == "Accepted" ]]; then
    # Accepted is terminal: it cannot already carry superseded_by (that would imply a transition out)
    if [[ "${superseded_by_len:-0}" -gt 0 ]]; then
      VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname} (id ${id:-<missing>}): impossible lifecycle state — status 'Accepted' is terminal but 'links.superseded_by' is set (Accepted -> Superseded requires a new superseding record; update status to Superseded).")
    fi
  fi

  # --- verification-criteria heuristic (AC-GH63-6, DEC-10/13) ---
  if [[ "$status" == "Accepted" ]]; then
    local body has_vc
    body="$(_record_body "$file")"
    # non-empty '## Verification Criteria' section: heading present AND some non-empty body line before next '## '
    has_vc="$(awk '
      BEGIN { in_vc = 0; found = 0 }
      /^##[[:space:]]+Verification Criteria/ { in_vc = 1; next }
      /^##[[:space:]]+/ { if (in_vc) in_vc = 0 }
      in_vc && /[[:alnum:]]/ { found = 1 }
      END { print (found ? "yes" : "no") }
    ' <<<"$body")"
    if [[ "$has_vc" != "yes" ]]; then
      VALIDATION_WARNS+=("[HEURISTIC] ${LOG_TAG} ${fname} (id ${id:-<missing>}): Accepted record body lacks a non-empty '## Verification Criteria' section. [HEURISTIC] best-effort check — NOT a structural guarantee (body-content machinery owned by GH-64). Non-blocking warning (exit 0).")
    fi
  fi

  # --- migration lint: warn on legacy shapes (non-destructive) ---
  if [[ "$lint_mode" == "true" ]]; then
    if [[ "$has_classification" == "false" ]]; then
      : # already warned above
    fi
  fi
}

_check_date() {
  local -r json="$1" fname="$2" id="$3" field="$4"
  local val
  val="$(_jq -r --arg k "$field" '.[$k] // empty' <<<"$json")"
  if [[ -n "$val" && "$val" != "null" && ! "$val" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
    VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname} (id ${id:-<missing>}): field '${field}'='${val}' is not a valid YYYY-MM-DD date.")
  fi
}

