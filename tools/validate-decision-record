die() { log_err "$@"; exit "${EXIT_USAGE}"; }

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"
}

# jq wrapper (mockable)
_jq() { "${JQ_CMD:-jq}" "$@"; }

