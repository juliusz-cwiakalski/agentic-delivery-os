# validate_summary <file> -> appends to VALIDATION_ERRORS / VALIDATION_WARNS
validate_summary() {
  local -r file="$1"
  local -r fname="$(basename -- "$file")"
  if [[ ! -f "$file" ]]; then
    VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname}: planning-summary file not found.")
    return
  fi
  # Summary fixtures are JSON (validated with python stdlib json — NOT import yaml).
  local json
  if ! json="$(python3 -c 'import json,sys; print(json.dumps(json.load(open(sys.argv[1],encoding="utf-8"))))' "$file" 2>/dev/null)"; then
    VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname}: planning-summary is not valid JSON.")
    return
  fi

  # Legacy alias normalization (adr.* -> canonical)
  local norm
  norm="$(python3 - "$file" <<'PY'
import json, sys
d = json.load(open(sys.argv[1], encoding='utf-8'))
adr = d.get('adr') if isinstance(d, dict) else None
if isinstance(adr, dict):
    for k in ('id','type','title','slug'):
        canon = {'id':'decision_id','type':'decision_type','title':'title','slug':'slug'}[k]
        if adr.get(k) is not None and canon not in d:
            d[canon] = adr[k]
print(json.dumps(d, ensure_ascii=False))
PY
)"
  json="$norm"

  local did dtype title
  did="$(_jq -r '.decision_id // empty' <<<"$json")"
  dtype="$(_jq -r '.decision_type // empty' <<<"$json")"
  title="$(_jq -r '.title // empty' <<<"$json")"

  for rf in decision_id decision_type title hard_requirements decision_drivers alternatives; do
    if [[ "$(_jq -r --arg k "$rf" 'has($k)' <<<"$json")" == "false" ]]; then
      VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname}: planning-summary required field '${rf}' is missing.")
    fi
  done

  local dt_re; dt_re="$(_join_pipe VALID_DECISION_TYPES)"
  if [[ -n "$dtype" && ! "$dtype" =~ ^($dt_re)$ ]]; then
    VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname} (decision ${did:-<missing>}): field 'decision_type'='${dtype}' is not valid. Allowed: adr|pdr|tdr|bdr|odr.")
  fi

  # hard_requirements ∩ decision_drivers == empty (HARD FAIL — AC-GH63-5)
  local overlap
  overlap="$(python3 - "$file" <<'PY'
import json, sys
d = json.load(open(sys.argv[1], encoding='utf-8'))
adr = d.get('adr') if isinstance(d, dict) else None
if isinstance(adr, dict):
    for k in ('id','type','title','slug'):
        canon = {'id':'decision_id','type':'decision_type','title':'title','slug':'slug'}[k]
        if adr.get(k) is not None and canon not in d:
            d[canon] = adr[k]
reqs = d.get('hard_requirements') or []
drivers = [str(x) for x in (d.get('decision_drivers') or [])]
req_factors = []
for r in reqs:
    if isinstance(r, dict):
        for key in ('statement','id','name'):
            if r.get(key) is not None:
                req_factors.append(str(r[key])); break
    else:
        req_factors.append(str(r))
inter = sorted(set(req_factors) & set(drivers))
print('\n'.join(inter))
PY
)"
  if [[ -n "$overlap" ]]; then
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      VALIDATION_ERRORS+=("[ERROR] ${LOG_TAG} ${fname}: factor '${line}' appears in BOTH hard_requirements and decision_drivers. A hard requirement is a binary pass/fail gate; a driver is a tradeable preference — they must be disjoint (hard_requirements ∩ decision_drivers = ∅).")
    done <<<"$overlap"
  fi

  # non-negotiable-constraint violation in chosen option (HEURISTIC/WARN — AC-GH63-6, DEC-13)
  local chosen_violations
  chosen_violations="$(python3 - "$file" <<'PY'
import json, sys
d = json.load(open(sys.argv[1], encoding='utf-8'))
reqs = d.get('hard_requirements') or []
negotiable = {}
for r in reqs:
    if isinstance(r, dict) and r.get('id') is not None:
        negotiable[str(r['id'])] = str(r.get('negotiable','yes'))
alts = d.get('alternatives') or []
out = []
for a in alts:
    if not isinstance(a, dict) or not a.get('chosen'):
        continue
    cc = a.get('constraint_compliance') or {}
    name = a.get('name','<unnamed>')
    for cid, verdict in cc.items():
        v = str(verdict).lower()
        if v in ('fail','violation','violated','no') and negotiable.get(str(cid),'yes') == 'no':
            out.append("%s\t%s" % (name, cid))
print('\n'.join(out))
PY
)"
  if [[ -n "$chosen_violations" ]]; then
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local oname oconstr
      oname="${line%%$'\t'*}"
      oconstr="${line#*$'\t'}"
      VALIDATION_WARNS+=("[WARN] ${LOG_TAG} ${fname}: [HEURISTIC] chosen option '${oname}' violates non-negotiable constraint '${oconstr}' (negotiable=no). Best-effort detection from planning-summary compliance data — NOT a structural guarantee (body-content/snapshot machinery owned by GH-64). Non-blocking warning (exit 0).")
    done <<<"$chosen_violations"
  fi
}

# ============================================================================
# DOMAIN: schema-vs-validator coverage (AC-GH63-15)
# ============================================================================

# coverage_check <repo_root> -> emits report; sets global COVERAGE_UNCOVERED count
coverage_check() {
  local -r repo_root="$1"
  local -r fm_schema="${repo_root}/schemas/decision-record-frontmatter.schema.json"
  local -r ps_schema="${repo_root}/schemas/decision-planning-summary.schema.json"
  local -r cov_map="${repo_root}/tools/.tests/fixtures/coverage-map.json"

  local report
  report="$(python3 - "$fm_schema" "$ps_schema" "$cov_map" <<'PY'
import json, sys, os
fm = json.load(open(sys.argv[1], encoding='utf-8'))
ps = json.load(open(sys.argv[2], encoding='utf-8'))
cov_path = sys.argv[3]
cov = {}
if os.path.exists(cov_path):
    cov = json.load(open(cov_path, encoding='utf-8'))

rules = []  # (rule_id, kind, description)

def structural_rules(schema, prefix=''):
    out = []
    props = schema.get('properties', {})
    req = schema.get('required', [])
    for f in req:
        out.append(("top.required.%s" % f, "required", "top-level required field '%s'" % f))
    for name, sub in props.items():
        if not isinstance(sub, dict):
            continue
        if 'enum' in sub:
            out.append(("top.enum.%s" % name, "enum", "top-level enum for '%s'" % name))
        if 'pattern' in sub:
            out.append(("top.pattern.%s" % name, "pattern", "top-level pattern for '%s'" % name))
        if sub.get('type') == 'array' and 'minItems' in sub:
            out.append(("top.minItems.%s" % name, "minItems", "top-level minItems for '%s'" % name))
        # nested object property enums (one level deep)
        if 'properties' in sub and isinstance(sub['properties'], dict):
            for sname, ssub in sub['properties'].items():
                if isinstance(ssub, dict) and 'enum' in ssub:
                    out.append(("nested.enum.%s.%s" % (name, sname), "enum", "nested enum '%s.%s'" % (name, sname)))
    return out

rules += structural_rules(fm)
rules += structural_rules(ps)
# x-coverage-rules
for schema in (fm, ps):
    x = schema.get('x-coverage-rules', {}).get('rules', [])
    for r in x:
        rid = r.get('id')
        if rid:
            rules.append((rid, 'xrule', r.get('description','')))

# de-dup (keep order)
seen = {}; uniq = []
for rid, kind, desc in rules:
    if rid not in seen:
        seen[rid] = 1; uniq.append((rid, kind, desc))

covered = 0; uncovered = []
for rid, kind, desc in uniq:
    fixtures = cov.get(rid)
    if fixtures:
        covered += 1
    else:
        uncovered.append((rid, kind, desc))

print("RULESET: %d rules extracted from schemas (front-matter + planning-summary)" % len(uniq))
print("COVERED: %d rules mapped to >=1 fixture in coverage-map.json" % covered)
print("UNCOVERED: %d" % len(uncovered))
for rid, kind, desc in uncovered:
    print("  - %s  [%s]  %s" % (rid, kind, desc))
print("UNCOVERED_COUNT:%d" % len(uncovered))
PY
)"
  printf '%s\n' "${report}"
  COVERAGE_UNCOVERED="$(printf '%s\n' "${report}" | sed -n 's/^UNCOVERED_COUNT://p')"
  [[ -z "${COVERAGE_UNCOVERED:-}" ]] && COVERAGE_UNCOVERED="999"
}

