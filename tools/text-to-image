    log_info "[DRY-RUN] Would call: curl -s -X POST https://api.blackforestlabs.ai/v1/images/generate -H Authorization: Bearer $(sanitize_token "$api_key") -H Content-Type: application/json -d '$payload' (model: $model)"
    return "$EXIT_SUCCESS"
  fi
  response="$(retry_curl --max-time 60 -s -X POST "https://api.blackforestlabs.ai/v1/images/generate" \
    -H "Authorization: Bearer $api_key" \
    -H "Content-Type: application/json" \
    -d "$payload" 2>/dev/null)"

  local exit_code=$?
  if (( exit_code != 0 )); then
    local api_error
    api_error="$(extract_api_error "$response" 2>/dev/null)"
    log_err "BFL API call failed: ${api_error:-unknown error}"
    log_debug "Full response: ${response:0:500}"
    return "$exit_code"
  fi

  local inference_id
  inference_id="$(_jq -r '.inference_id // empty' <<< "$response" 2>/dev/null)"
  if [[ -z "$inference_id" ]]; then
    log_err "No inference_id in BFL response"
    return "$EXIT_SERVER_ERROR"
  fi

  # Poll for result
  local max_polls=30
  local poll_count=0
  while (( poll_count < max_polls )); do
    sleep 2
    response="$(retry_curl --max-time 60 -s "https://api.blackforestlabs.ai/v1/images/get/$inference_id" \
      -H "Authorization: Bearer $api_key" 2>/dev/null)"
    local status
    status="$(_jq -r '.status // empty' <<< "$response" 2>/dev/null)"
    if [[ "$status" == "COMPLETED" ]]; then
      local url
      url="$(_jq -r '.result.samples[0].url // empty' <<< "$response" 2>/dev/null)"
      if [[ -n "$url" ]]; then
        _curl -s -o "$output_path" "$url"
        log_info "Image generated with BFL ($model)"
        return "$EXIT_SUCCESS"
      fi
    elif [[ "$status" == "FAILED" ]]; then
      log_err "BFL generation failed"
      return "$EXIT_SERVER_ERROR"
    fi
    (( poll_count++ ))
  done

  log_err "BFL polling timeout"
  return "$EXIT_SERVER_ERROR"
}

