# OpenAI DALL-E provider
generate_image_openai() {
  local prompt="$1"
  local negative_prompt="$2"  # Not supported
  local width="$3"
  local height="$4"
  local quality="$5"  # Not used
  local output_path="$6"
  local model="${7:-dall-e-3}"

  local api_key="${OPENAI_API_KEY:-}"
  if [[ -z "$api_key" ]]; then
    log_debug "OpenAI API key not set"
    return "$EXIT_AUTH_FAILED"
  fi

  # Validate model
  case "$model" in
    dall-e-2|dall-e-3) ;;
    *) log_err "Unsupported OpenAI model: $model. Supported: dall-e-2, dall-e-3"; return "$EXIT_INVALID_PARAMS" ;;
  esac

  local size="${width}x${height}"
  local payload
  payload="$(_jq -n --arg prompt "$prompt" --arg size "$size" --arg model "$model" '{prompt: $prompt, model: $model, size: $size, response_format: "url"}' 2>/dev/null)"

  if [[ "${DRY_RUN}" == "true" ]]; then
    log_info "[DRY-RUN] Would call: curl -s -X POST https://api.openai.com/v1/images/generations -H Authorization: Bearer $(sanitize_token "$api_key") -H Content-Type: application/json -d '$payload'"
    return "$EXIT_SUCCESS"
  fi

  response="$(retry_curl --max-time 60 -s -X POST "https://api.openai.com/v1/images/generations" \
    -H "Authorization: Bearer $api_key" \
    -H "Content-Type: application/json" \
    -d "$payload")"

  local exit_code=$?
  if (( exit_code != 0 )); then
    local api_error
    api_error="$(extract_api_error "$response" 2>/dev/null)"
    log_err "OpenAI API call failed: ${api_error:-unknown error}"
    log_debug "Full response: ${response:0:500}"
    return "$exit_code"
  fi

  local url
  url="$(_jq -r '.data[0].url // empty' <<< "$response" 2>/dev/null)"
  if [[ -z "$url" ]]; then
    log_err "No URL in OpenAI response"
    return "$EXIT_SERVER_ERROR"
  fi

  if ! _curl -s -o "$output_path" "$url"; then
    log_err "Failed to download image from $url"
    return "$EXIT_NETWORK_ERROR"
  fi

  log_info "Image generated with OpenAI ($model)"
  return "$EXIT_SUCCESS"
}

# Stability AI provider
generate_image_stability() {
  local prompt="$1"
  local negative_prompt="$2"
  local width="$3"
  local height="$4"
  local quality="$5"  # Not used
  local output_path="$6"
  local model="${7:-stable-diffusion-v1-6}"

  local api_key="${STABILITY_API_KEY:-}"
  if [[ -z "$api_key" ]]; then
    log_debug "Stability API key not set"
    return "$EXIT_AUTH_FAILED"
  fi

  local payload
  payload="$(_jq -n --arg prompt "$prompt" --arg negative "$negative_prompt" --arg w "$width" --arg h "$height" \
    '{text_prompts: [{text: $prompt}, {text: $negative, weight: -1}], cfg_scale: 7, height: ($h|tonumber), width: ($w|tonumber), samples: 1, steps: 20}' 2>/dev/null)"

  local response
  if [[ "${DRY_RUN}" == "true" ]]; then
    log_info "[DRY-RUN] Would call: curl -s -X POST https://api.stability.ai/v1/generation/$model/text-to-image -H Accept: application/json -H Authorization: Bearer $(sanitize_token "$api_key") -H Content-Type: application/json -d '$payload'"
    return "$EXIT_SUCCESS"
  fi
  response="$(retry_curl --max-time 60 -s -X POST "https://api.stability.ai/v1/generation/$model/text-to-image" \
    -H "Accept: application/json" \
    -H "Authorization: Bearer $api_key" \
    -H "Content-Type: application/json" \
    -d "$payload" 2>/dev/null)"

  local exit_code=$?
  if (( exit_code != 0 )); then
    local api_error
    api_error="$(extract_api_error "$response" 2>/dev/null)"
    log_err "Stability API call failed: ${api_error:-unknown error}"
    log_debug "Full response: ${response:0:500}"
    return "$exit_code"
  fi

  local base64
  base64="$(_jq -r '.artifacts[0].base64 // empty' <<< "$response" 2>/dev/null)"
  if [[ -z "$base64" ]]; then
    log_err "No base64 in Stability response"
    return "$EXIT_SERVER_ERROR"
  fi

  if ! base64 -d <<< "$base64" > "$output_path" 2>/dev/null; then
    log_err "Failed to decode base64"
    return "$EXIT_GENERAL_ERROR"
  fi

  log_info "Image generated with Stability AI ($model)"
  return "$EXIT_SUCCESS"
}

# ============================================================================
# GOOGLE AUTHENTICATION FUNCTIONS
# ============================================================================

# Obtain Google access token via service account JSON key file (JWT-based)
# Requires: openssl, jq, curl
# The JSON file must contain: client_email, private_key, token_uri
obtain_google_token_from_json() {
  local credentials_file="$1"

  if [[ ! -f "$credentials_file" ]]; then
    log_err "Google credentials file not found: $credentials_file"
    return "$EXIT_AUTH_FAILED"
  fi

  # Extract fields from JSON
  local client_email private_key token_uri
  client_email="$(_jq -r '.client_email // empty' "$credentials_file" 2>/dev/null)"
  private_key="$(_jq -r '.private_key // empty' "$credentials_file" 2>/dev/null)"
  token_uri="$(_jq -r '.token_uri // "https://oauth2.googleapis.com/token"' "$credentials_file" 2>/dev/null)"

  if [[ -z "$client_email" || -z "$private_key" ]]; then
    log_err "Google credentials file missing client_email or private_key"
    return "$EXIT_AUTH_FAILED"
  fi

  if ! command -v openssl >/dev/null 2>&1; then
    log_err "openssl is required for service account JWT authentication"
    return "$EXIT_AUTH_FAILED"
  fi

  # Build JWT header
  local header='{"alg":"RS256","typ":"JWT"}'
  local header_b64
  header_b64="$(echo -n "$header" | base64 -w 0 2>/dev/null || echo -n "$header" | base64 | tr -d '\n')"
  header_b64="$(echo -n "$header_b64" | tr '+/' '-_' | tr -d '=')"

  # Build JWT payload (expires in 1 hour)
  local iat exp
  iat="$(date +%s)"
  exp="$(( iat + 3600 ))"
  local payload='{"iss":"'"$client_email"'","scope":"https://www.googleapis.com/auth/cloud-platform","aud":"'"$token_uri"'","exp":'"$exp"',"iat":'"$iat"'}'
  local payload_b64
  payload_b64="$(echo -n "$payload" | base64 -w 0 2>/dev/null || echo -n "$payload" | base64 | tr -d '\n')"
  payload_b64="$(echo -n "$payload_b64" | tr '+/' '-_' | tr -d '=')"

  # Sign with private key (RS256)
  local signature
  signature="$(echo -n "${header_b64}.${payload_b64}" | openssl dgst -sha256 -sign <(echo "$private_key") 2>/dev/null | base64 -w 0 2>/dev/null || echo -n "${header_b64}.${payload_b64}" | openssl dgst -sha256 -sign <(echo "$private_key") 2>/dev/null | base64 | tr -d '\n')"
  if [[ -z "$signature" ]]; then
    log_err "Failed to sign JWT with service account private key"
    return "$EXIT_AUTH_FAILED"
  fi
  signature="$(echo -n "$signature" | tr '+/' '-_' | tr -d '=')"

  local jwt="${header_b64}.${payload_b64}.${signature}"

  # Exchange JWT for access token
  local token_response
  token_response="$(_curl -s -X POST "$token_uri" \
    -H "Content-Type: application/x-www-form-urlencoded" \
    -d "grant_type=urn%3Aietf%3Aparams%3Aoauth%3Agrant-type%3Ajwt-bearer&assertion=${jwt}" 2>/dev/null)"

  local access_token
  access_token="$(_jq -r '.access_token // empty' <<< "$token_response" 2>/dev/null)"
  if [[ -z "$access_token" ]]; then
    local error_msg
    error_msg="$(_jq -r '.error_description // .error // "unknown error"' <<< "$token_response" 2>/dev/null)"
    log_err "Failed to obtain Google access token: $error_msg"
    return "$EXIT_AUTH_FAILED"
  fi

  # Cache the token
  _GOOGLE_ACCESS_TOKEN="$access_token"
  _GOOGLE_TOKEN_EXPIRY="$exp"

  echo "$access_token"
  return "$EXIT_SUCCESS"
}

# Obtain Google access token via gcloud CLI
obtain_google_token_from_gcloud() {
  if ! command -v gcloud >/dev/null 2>&1; then
    log_debug "gcloud CLI not available"
    return "$EXIT_AUTH_FAILED"
  fi

  local access_token
  access_token="$(gcloud auth print-access-token 2>/dev/null)"
  if [[ -z "$access_token" ]]; then
    # Try application-default credentials
    access_token="$(gcloud auth application-default print-access-token 2>/dev/null)"
  fi

  if [[ -z "$access_token" ]]; then
    log_err "Failed to obtain access token from gcloud CLI"
    return "$EXIT_AUTH_FAILED"
  fi

  # Cache the token (gcloud tokens are typically valid for 1 hour)
  _GOOGLE_ACCESS_TOKEN="$access_token"
  _GOOGLE_TOKEN_EXPIRY="$(( $(date +%s) + 3500 ))"

  echo "$access_token"
  return "$EXIT_SUCCESS"
}

# Obtain Google access token using configured auth method
# Priority: --google-auth-method flag > GOOGLE_CREDENTIALS file > GOOGLE_API_KEY > gcloud CLI
obtain_google_access_token() {
  local auth_method="${GOOGLE_AUTH_METHOD:-auto}"
  local credentials_file="${GOOGLE_CREDENTIALS:-}"

  # Check if cached token is still valid (with 5-minute buffer)
  local now
  now="$(date +%s)"
  if [[ -n "$_GOOGLE_ACCESS_TOKEN" ]] && (( _GOOGLE_TOKEN_EXPIRY > now + 300 )); then
    log_debug "Using cached Google access token"
    echo "$_GOOGLE_ACCESS_TOKEN"
    return "$EXIT_SUCCESS"
  fi

  case "$auth_method" in
    json|service-account)
      if [[ -z "$credentials_file" ]]; then
        log_err "GOOGLE_CREDENTIALS must be set when using --google-auth-method json"
        return "$EXIT_AUTH_FAILED"
      fi
      obtain_google_token_from_json "$credentials_file"
      return $?
      ;;
    gcloud)
      obtain_google_token_from_gcloud
      return $?
      ;;
    api-key)
      # Use GOOGLE_API_KEY directly (legacy mode)
      if [[ -n "${GOOGLE_API_KEY:-}" ]]; then
        echo "${GOOGLE_API_KEY}"
        return "$EXIT_SUCCESS"
      fi
      log_err "GOOGLE_API_KEY must be set when using --google-auth-method api-key"
      return "$EXIT_AUTH_FAILED"
      ;;
    auto)
      # Auto-detect: try JSON credentials first, then gcloud, then API key
      if [[ -n "$credentials_file" && -f "$credentials_file" ]]; then
        log_debug "Auto-detected Google service account JSON credentials"
        obtain_google_token_from_json "$credentials_file"
        return $?
      fi
      if command -v gcloud >/dev/null 2>&1; then
        log_debug "Auto-detected gcloud CLI for Google authentication"
        local token
        token="$(obtain_google_token_from_gcloud 2>/dev/null)" && {
          echo "$token"
          return "$EXIT_SUCCESS"
        }
      fi
      if [[ -n "${GOOGLE_API_KEY:-}" ]]; then
        log_debug "Using GOOGLE_API_KEY for Google authentication (legacy)"
        echo "${GOOGLE_API_KEY}"
        return "$EXIT_SUCCESS"
      fi
      log_debug "No Google authentication method available"
      return "$EXIT_AUTH_FAILED"
      ;;
    *)
      log_err "Invalid --google-auth-method: $auth_method (valid: auto, json, service-account, gcloud, api-key)"
      return "$EXIT_INVALID_PARAMS"
      ;;
  esac
}

# Determine the correct API endpoint and request format for a Google Imagen model
# Imagen 4 uses :predict with publishers/google path
# Imagen 3 and earlier use the older :predict endpoint
google_imagen_api_url() {
  local project="$1"
  local location="$2"
  local model="$3"

  # All Imagen models use the publishers/google/models path with :predict
  echo "https://${location}-aiplatform.googleapis.com/v1/projects/${project}/locations/${location}/publishers/google/models/${model}:predict"
}

# Build request payload for Google Imagen model
google_imagen_build_payload() {
  local prompt="$1"
  local negative_prompt="$2"
  local width="$3"
  local height="$4"
  local model="$5"
  local sample_count="${6:-1}"

  # Determine aspect ratio from dimensions
  local aspect_ratio=""
  if (( width == height )); then
    aspect_ratio="1:1"
  elif (( width * 3 == height * 4 )); then
    aspect_ratio="4:3"
  elif (( width * 4 == height * 3 )); then
    aspect_ratio="3:4"
  elif (( width * 9 == height * 16 )); then
    aspect_ratio="16:9"
  elif (( width * 16 == height * 9 )); then
    aspect_ratio="9:16"
  fi

  # Build parameters object
  local params_args=(
    --arg prompt "$prompt"
    --argjson sampleCount "$sample_count"
  )

  # Add aspect ratio if determined
  if [[ -n "$aspect_ratio" ]]; then
    params_args+=(--arg aspectRatio "$aspect_ratio")
  fi

  # Add negative prompt if provided (supported on some models)
  local negative_prompt_field=""
  if [[ -n "$negative_prompt" ]]; then
    negative_prompt_field=', "negativePrompt": $negativePrompt'
    params_args+=(--arg negativePrompt "$negative_prompt")
  fi

  local jq_filter
  if [[ -n "$aspect_ratio" ]]; then
    jq_filter='{instances: [{prompt: $prompt}], parameters: {sampleCount: $sampleCount, aspectRatio: $aspectRatio'"$negative_prompt_field"'}}'
  else
    jq_filter='{instances: [{prompt: $prompt}], parameters: {sampleCount: $sampleCount'"$negative_prompt_field"'}}'
  fi

  _jq -n "${params_args[@]}" "$jq_filter" 2>/dev/null
}

# Google Imagen provider
# Supports authentication via:
#   1. Service account JSON key file (GOOGLE_CREDENTIALS env var or --google-credentials)
#   2. gcloud CLI (gcloud auth print-access-token)
#   3. GOOGLE_API_KEY env var (legacy)
# Supports Imagen models:
#   - imagen-4.0-generate-001 (Imagen 4 standard)
#   - imagen-4.0-ultra-generate-001 (Imagen 4 ultra)
#   - imagen-4.0-fast-generate-001 (Imagen 4 fast)
#   - imagen-3.0-generate-001 (Imagen 3)
#   - imagegeneration (legacy Imagen 2)
generate_image_google() {
  local prompt="$1"
  local negative_prompt="$2"
  local width="$3"
  local height="$4"
  local quality="$5"
  local output_path="$6"
  local model="${7:-imagen-4.0-generate-001}"

  local project="${GOOGLE_PROJECT_ID:-}"
  local location="${GOOGLE_LOCATION:-us-central1}"

  # Obtain access token via configured auth method
  local access_token
  access_token="$(obtain_google_access_token 2>/dev/null)"
  if [[ -z "$access_token" ]]; then
    log_debug "Google authentication failed (no credentials, gcloud, or API key available)"
    return "$EXIT_AUTH_FAILED"
  fi

  # Project ID is required for Vertex AI endpoints
  if [[ -z "$project" ]]; then
    # Try to extract from credentials file
    if [[ -n "${GOOGLE_CREDENTIALS:-}" && -f "${GOOGLE_CREDENTIALS}" ]]; then
      project="$(_jq -r '.project_id // empty' "${GOOGLE_CREDENTIALS}" 2>/dev/null)"
    fi
    # Try gcloud config
    if [[ -z "$project" ]] && command -v gcloud >/dev/null 2>&1; then
      project="$(gcloud config get-value project 2>/dev/null || true)"
    fi
    if [[ -z "$project" ]]; then
      log_err "GOOGLE_PROJECT_ID is required (set via env var, credentials file, or gcloud config)"
      return "$EXIT_AUTH_FAILED"
    fi
  fi

  # Validate model
  case "$model" in
    imagen-4.0-generate-001|imagen-4.0-ultra-generate-001|imagen-4.0-fast-generate-001|\
    imagen-3.0-generate-001|imagen-3.0-capability-001|\
    imagegeneration)
      ;;
    *)
      log_err "Unsupported Google Imagen model: $model. Supported: imagen-4.0-generate-001, imagen-4.0-ultra-generate-001, imagen-4.0-fast-generate-001, imagen-3.0-generate-001, imagegeneration"
      return "$EXIT_INVALID_PARAMS"
      ;;
  esac

  # Build API URL
  local api_url
  api_url="$(google_imagen_api_url "$project" "$location" "$model")"

  # Build payload
  local payload
  payload="$(google_imagen_build_payload "$prompt" "$negative_prompt" "$width" "$height" "$model")"

  if [[ "${DRY_RUN}" == "true" ]]; then
    log_info "[DRY-RUN] Would call: curl -s -X POST $api_url -H Authorization: Bearer $(sanitize_token "$access_token") -H Content-Type: application/json -d '$payload'"
    return "$EXIT_SUCCESS"
  fi

  local response
  response="$(retry_curl --max-time 120 -s -X POST "$api_url" \
    -H "Authorization: Bearer $access_token" \
    -H "Content-Type: application/json" \
    -d "$payload" 2>/dev/null)"

  local exit_code=$?
  if (( exit_code != 0 )); then
    local api_error
    api_error="$(extract_api_error "$response" 2>/dev/null)"
    log_err "Google Imagen API call failed: ${api_error:-unknown error}"
    log_debug "Full response: ${response:0:500}"
    return "$exit_code"
  fi

  # Extract base64 image data from response
  # Vertex AI Imagen returns predictions[].bytesBase64Encoded
  local img_base64
  img_base64="$(_jq -r '.predictions[0].bytesBase64Encoded // empty' <<< "$response" 2>/dev/null)"
  if [[ -z "$img_base64" ]]; then
    local error_msg
    error_msg="$(_jq -r '.error.message // empty' <<< "$response" 2>/dev/null)"
    if [[ -n "$error_msg" ]]; then
      log_err "Google Imagen API error: $error_msg"
    else
      log_err "No image data in Google Imagen response"
    fi
    return "$EXIT_SERVER_ERROR"
  fi

  if ! base64 -d <<< "$img_base64" > "$output_path" 2>/dev/null; then
    log_err "Failed to decode base64 image data"
    return "$EXIT_GENERAL_ERROR"
  fi

  log_info "Image generated with Google Imagen ($model)"
  return "$EXIT_SUCCESS"
}

# Hugging Face provider
generate_image_huggingface() {
  local prompt="$1"
