# Generate cache key: SHA-256 hash of relevant configuration
compute_cache_key() {
  local prompt="$1"
  local negative_prompt="$2"
  local width="$3"
  local height="$4"
  local quality="$5"
  local provider="$6"
  local model="${7:-}"

  # Concatenate inputs and hash
  local input="${prompt}|${negative_prompt}|${width}|${height}|${quality}|${provider}|${model}"
  if command -v sha256sum >/dev/null 2>&1; then
    echo -n "$input" | sha256sum | cut -d' ' -f1
  elif command -v shasum >/dev/null 2>&1; then
    echo -n "$input" | shasum -a 256 | cut -d' ' -f1
  else
    log_warn "No SHA-256 tool available, using fallback hash"
    # Fallback: simple hash (not secure, but deterministic)
    echo -n "$input" | cksum | cut -d' ' -f1
  fi
}

# Check cache for existing image
cache_lookup() {
  local cache_key="$1"
  local output_path="$2"

  local cache_file="${CACHE_DIR}/${cache_key}"
  local metadata_file="${cache_file}.metadata"

  if [[ -f "$cache_file" && -f "$metadata_file" ]]; then
    # Check if metadata hash matches
    local stored_hash
    stored_hash="$(jq -r '.cache_key // empty' "$metadata_file" 2>/dev/null)"
    if [[ "$stored_hash" == "$cache_key" ]]; then
      log_debug "Cache hit: copying from $cache_file to $output_path"
      if cp "$cache_file" "$output_path"; then
        log_info "Image retrieved from cache"
        return 0
      fi
    fi
  fi

  return 1  # Cache miss
}

# Store image in cache with metadata
cache_store() {
  local cache_key="$1"
  local output_path="$2"
  local prompt="$3"
  local negative_prompt="$4"
  local width="$5"
  local height="$6"
  local quality="$7"
  local provider="$8"
  local model="$9"
  local timestamp
  timestamp="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  local cache_file="${CACHE_DIR}/${cache_key}"
  local metadata_file="${cache_file}.metadata"

  # Copy image to cache
  if cp "$output_path" "$cache_file"; then
    # Create metadata JSON
    local metadata
    metadata="$(_jq -n \
      --arg cache_key "$cache_key" \
      --arg timestamp "$timestamp" \
      --arg provider "$provider" \
      --arg model "$model" \
      --arg prompt "$prompt" \
      --arg negative_prompt "$negative_prompt" \
      --arg width "$width" \
      --arg height "$height" \
      --arg quality "$quality" \
      '{cache_key: $cache_key, timestamp: $timestamp, provider: $provider, model: $model, prompt: $prompt, negative_prompt: $negative_prompt, width: ($width|tonumber), height: ($height|tonumber), quality: $quality}' 2>/dev/null)"

    if echo "$metadata" > "$metadata_file"; then
      log_debug "Image cached with key $cache_key"
      return 0
    fi
  fi

  log_warn "Failed to cache image"
  return 1
}

# Embed metadata in image or create sidecar
embed_metadata() {
  local output_path="$1"
  local artist="$2"
  local copyright="$3"
  local keywords="$4"
  local description="$5"
  local prompt="$6"
  local provider="$7"

  local sidecar_file="${output_path}.metadata"

  if command -v exiftool >/dev/null 2>&1; then
    # Try to embed in image
    local exif_args=()
    [[ -n "$artist" ]] && exif_args+=(-Artist="$artist")
    [[ -n "$copyright" ]] && exif_args+=(-Copyright="$copyright")
    [[ -n "$keywords" ]] && exif_args+=(-Keywords="$keywords")
    [[ -n "$description" ]] && exif_args+=(-Description="$description")
    [[ -n "$prompt" ]] && exif_args+=(-Comment="Prompt: $prompt")
    [[ -n "$provider" ]] && exif_args+=(-Software="$provider")

    if _exiftool "${exif_args[@]}" "$output_path" >/dev/null 2>&1; then
      log_debug "Metadata embedded in image using exiftool"
      return 0
    else
      log_debug "Failed to embed metadata in image, using sidecar"
    fi
  fi

  # Fallback: create sidecar JSON
  local metadata
  metadata="$(_jq -n \
    --arg artist "$artist" \
    --arg copyright "$copyright" \
    --arg keywords "$keywords" \
    --arg description "$description" \
    --arg prompt "$prompt" \
    --arg provider "$provider" \
    '{artist: $artist, copyright: $copyright, keywords: $keywords, description: $description, prompt: $prompt, provider: $provider}' 2>/dev/null)"

  if echo "$metadata" > "$sidecar_file"; then
    log_debug "Metadata saved to sidecar file $sidecar_file"
    return 0
  fi

  log_warn "Failed to save metadata"
  return 1
}

