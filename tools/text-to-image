# Process batch jobs sequentially
process_batch_sequential() {
  local jobs="$1"  # JSON array of jobs

  local total_jobs
  total_jobs="$(echo "$jobs" | _jq length)"
  local success_count=0
  local failure_count=0
  local results=()

  log_info "Starting sequential batch processing of $total_jobs jobs"

  for (( i=0; i<total_jobs; i++ )); do
    local job
    job="$(echo "$jobs" | _jq ".[$i]")"

    local prompt output quality width height negative_prompt artist copyright keywords description embed_metadata provider model
    prompt="$(echo "$job" | _jq -r '.prompt // empty')"
    output="$(echo "$job" | _jq -r '.output // empty')"
    quality="$(echo "$job" | _jq -r '.quality // "high"')"
    width="$(echo "$job" | _jq -r '.width // 1024')"
    height="$(echo "$job" | _jq -r '.height // 1024')"
    negative_prompt="$(echo "$job" | _jq -r '.negative_prompt // empty')"
    embed_metadata="$(echo "$job" | _jq -r '.embed_metadata // "false"')"
    artist="$(echo "$job" | _jq -r '.artist // empty')"
    copyright="$(echo "$job" | _jq -r '.copyright // empty')"
    keywords="$(echo "$job" | _jq -r '.keywords // empty')"
    description="$(echo "$job" | _jq -r '.description // empty')"
    provider="$(echo "$job" | _jq -r '.provider // empty')"
    model="$(echo "$job" | _jq -r '.model // empty')"

    log_info "Processing job $((i+1))/$total_jobs: $output"

    # Override globals for this job
    local old_embed="${EMBED_METADATA:-}" old_artist="${ARTIST:-}" old_copyright="${COPYRIGHT:-}" old_keywords="${KEYWORDS:-}" old_desc="${DESCRIPTION:-}"
    EMBED_METADATA="$embed_metadata"
    ARTIST="$artist"
    COPYRIGHT="$copyright"
    KEYWORDS="$keywords"
    DESCRIPTION="$description"

    # Set job log file
    local job_log_file="${JOB_LOG_DIR}/$(basename "${output%.*}").log"
    JOB_LOG_FILE="$job_log_file"

      if timeout_wrapper 60 generate_image "$prompt" "$negative_prompt" "$width" "$height" "$quality" "$output" "$provider" "$model"; then
      results+=("SUCCESS: $output")
      (( success_count++ ))
    else
      local exit_code=$?
      if (( exit_code == 124 )); then
        log_err "Job timed out: $output"
        results+=("TIMEOUT: $output")
      else
        results+=("FAILED ($exit_code): $output")
      fi
      (( failure_count++ ))
    fi

    # Restore
    EMBED_METADATA="$old_embed"
    ARTIST="$old_artist"
    COPYRIGHT="$old_copyright"
    KEYWORDS="$old_keywords"
    DESCRIPTION="$old_desc"
    unset JOB_LOG_FILE
  done

  # Summary
  log_info "Batch completed: $success_count succeeded, $failure_count failed"
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    local json_results
    json_results="$(printf '%s\n' "${results[@]}" | _jq -R -s 'split("\n")[:-1] | map(split(": ")) | map({status: .[0], output: .[1]})' 2>/dev/null)"
    echo "{\"batch_summary\": {\"total\": $total_jobs, \"success\": $success_count, \"failure\": $failure_count}, \"results\": $json_results}"
  else
    printf '%s\n' "${results[@]}"
  fi

  if (( failure_count > 0 )); then
    return "$EXIT_BATCH_PARTIAL_FAILURE"
  fi
  return "$EXIT_SUCCESS"
}

# Process batch jobs in parallel
process_batch_parallel() {
  local jobs="$1"  # JSON array of jobs
  local max_parallel="${MAX_PARALLEL:-$(nproc 2>/dev/null || echo 4)}"

  local total_jobs
  total_jobs="$(echo "$jobs" | _jq length)"
  log_info "Starting parallel batch processing of $total_jobs jobs (max $max_parallel concurrent)"

  # Create temp files for results
  local results_file
  results_file="$(mktemp)"

  # Run jobs in parallel
  local pids=()
  local job_count=0
  for (( i=0; i<total_jobs; i++ )); do
    local job
    job="$(echo "$jobs" | _jq ".[$i]")"

    # Extract job params
    local prompt output quality width height negative_prompt embed_metadata artist copyright keywords description provider model
    prompt="$(echo "$job" | _jq -r '.prompt // empty')"
    output="$(echo "$job" | _jq -r '.output // empty')"
    quality="$(echo "$job" | _jq -r '.quality // "high"')"
    width="$(echo "$job" | _jq -r '.width // 1024')"
    height="$(echo "$job" | _jq -r '.height // 1024')"
    negative_prompt="$(echo "$job" | _jq -r '.negative_prompt // empty')"
    embed_metadata="$(echo "$job" | _jq -r '.embed_metadata // "false"')"
    artist="$(echo "$job" | _jq -r '.artist // empty')"
    copyright="$(echo "$job" | _jq -r '.copyright // empty')"
    keywords="$(echo "$job" | _jq -r '.keywords // empty')"
    description="$(echo "$job" | _jq -r '.description // empty')"
    provider="$(echo "$job" | _jq -r '.provider // empty')"
    model="$(echo "$job" | _jq -r '.model // empty')"

    # Run in background
    (
      log_info "Starting parallel job $((i+1)): $output"
      # Set job log file
      local job_log_file="${JOB_LOG_DIR}/$(basename "${output%.*}").log"
      JOB_LOG_FILE="$job_log_file"
      # Set metadata variables for this job
      EMBED_METADATA="$embed_metadata"
      ARTIST="$artist"
      COPYRIGHT="$copyright"
      KEYWORDS="$keywords"
      DESCRIPTION="$description"
    if timeout_wrapper 60 generate_image "$prompt" "$negative_prompt" "$width" "$height" "$quality" "$output" "$provider" "$model"; then
        echo "SUCCESS: $output" >> "$results_file"
      else
        local exit_code=$?
        if (( exit_code == 124 )); then
          log_err "Job timed out: $output"
          echo "TIMEOUT: $output" >> "$results_file"
        else
          echo "FAILED ($exit_code): $output" >> "$results_file"
        fi
      fi
    ) &
    pids+=($!)

    (( job_count++ ))

    # Limit concurrent jobs
    if (( job_count >= max_parallel )); then
      wait "${pids[0]}"
      pids=("${pids[@]:1}")
      (( job_count-- ))
    fi
  done

  # Wait for remaining jobs
  for pid in "${pids[@]}"; do
    wait "$pid"
  done

  # Collect results
  local results
  mapfile -t results < "$results_file"
  rm -f "$results_file"

  local success_count=0 failure_count=0
  for result in "${results[@]}"; do
    if [[ "$result" =~ ^SUCCESS ]]; then
      (( success_count++ ))
    else
      (( failure_count++ ))
    fi
  done

  # Summary
  log_info "Batch completed: $success_count succeeded, $failure_count failed"
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    local json_results
    json_results="$(printf '%s\n' "${results[@]}" | _jq -R -s 'split("\n")[:-1] | map(split(": ")) | map({status: .[0], output: .[1]})' 2>/dev/null)"
    echo "{\"batch_summary\": {\"total\": $total_jobs, \"success\": $success_count, \"failure\": $failure_count}, \"results\": $json_results}"
  else
    printf '%s\n' "${results[@]}"
  fi

  if (( failure_count > 0 )); then
    return "$EXIT_BATCH_PARTIAL_FAILURE"
  fi
  return "$EXIT_SUCCESS"
}

# Optional cache cleanup: remove oldest files if cache size exceeds limit
cache_cleanup() {
  local max_size_mb="${CACHE_MAX_SIZE_MB:-100}"  # Default 100MB
  local current_size
  current_size="$(du -sm "$CACHE_DIR" 2>/dev/null | cut -f1 || echo 0)"

  if (( current_size > max_size_mb )); then
    log_info "Cache size ${current_size}MB exceeds limit ${max_size_mb}MB, cleaning up"
    # Remove oldest files (by mtime)
    find "$CACHE_DIR" -type f -name "*.metadata" -printf '%T@ %p\n' 2>/dev/null | sort -n | head -n 10 | cut -d' ' -f2- | while read -r metadata_file; do
      local cache_file="${metadata_file%.metadata}"
      rm -f "$cache_file" "$metadata_file"
    done
  fi
}

