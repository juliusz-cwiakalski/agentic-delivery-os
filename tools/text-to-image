# Sanitize token for logging
sanitize_token() {
  local token="$1"
  if [[ -z "$token" ]]; then
    echo "unset"
  else
    echo "${token:0:8}…****"
  fi
}

# Extract human-readable error message from provider JSON error response
# Tries common patterns across all providers:
#   OpenAI:      {"error": {"message": "...", "type": "...", "code": "..."}}
#   Stability:   {"message": "...", "name": "..."}
#   Google:      {"error": {"message": "...", "status": "...", "code": ...}}
#   HuggingFace: {"error": "..."} or {"error": {"message": "..."}}
#   BFL:         {"detail": "..."} or {"error": "..."}
#   Replicate:   {"detail": "..."}
#   SiliconFlow:  {"message": "...", "code": ...}
extract_api_error() {
  local response="$1"
  local msg=""
  msg="$(_jq -r '.error.message // .message // .detail // .error // empty' <<< "$response" 2>/dev/null)" || true
  if [[ -n "$msg" && "$msg" != "null" ]]; then
    printf '%s' "$msg"
  else
    printf '%s' "${response:0:200}"
  fi
}

# Shell-escape a value for safe eval
shell_escape() {
    printf '%q' "$1"
}

# Retry curl with exponential backoff
retry_curl() {
  local max_retries=3
  local attempt=0
  local delay=1
  local response
  local stderr_file
  stderr_file="$(mktemp)"

  while (( attempt < max_retries )); do
    # Capture response body and HTTP code
    response="$(_curl -s -w "\n%{http_code}" "$@" 2>"$stderr_file")"
    local http_code="${response##*$'\n'}"
    response="${response%$'\n'*}"

    # Handle malformed responses: default to 200 if http_code is not numeric
    if [[ ! "$http_code" =~ ^[0-9]+$ ]]; then
      http_code=200
    fi
    if [[ "${VERBOSE}" == "true" ]]; then
      local curl_stderr
      curl_stderr="$(cat "$stderr_file")"
      if [[ -n "$curl_stderr" ]]; then
        log_debug "Curl stderr: $curl_stderr"
      fi
    fi

    if (( http_code >= 200 && http_code < 300 )); then
      rm -f "$stderr_file"
      echo "$response"
      return 0
    fi

    if (( http_code == 429 )); then
      # Rate limited, wait for Retry-After or default
      local retry_after
      retry_after="$(_curl -s -I "$@" 2>/dev/null | grep -i retry-after | sed 's/.*: //' | tr -d '\r')"
      if [[ -n "$retry_after" ]] && [[ "$retry_after" =~ ^[0-9]+$ ]]; then
        delay="$retry_after"
      fi
      log_warn "Rate limited (429), retrying in $delay seconds"
    elif (( http_code >= 500 )); then
      log_warn "Server error ($http_code), retrying in $delay seconds (attempt $((attempt+1))/$max_retries)"
    else
      log_err "Request failed with HTTP $http_code"
      log_debug "Response body: ${response:0:500}"
      rm -f "$stderr_file"
      echo "$response"
      return "$EXIT_NETWORK_ERROR"
    fi

    sleep "$delay"
    (( delay *= 2 ))
    (( attempt++ ))
  done

  rm -f "$stderr_file"
  log_err "Max retries exceeded"
  return "$EXIT_NETWORK_ERROR"
}

# Custom timeout wrapper to handle subshell issues
timeout_wrapper() {
  local timeout_seconds="$1"
  shift
  local pid

  # Run in background
  "$@" &
  pid=$!

  # Wait with timeout
  local count=0
  while (( count < timeout_seconds )) && kill -0 "$pid" 2>/dev/null; do
    sleep 1
    (( count++ ))
  done

  if kill -0 "$pid" 2>/dev/null; then
    # Still running, kill it
    kill "$pid" 2>/dev/null
    wait "$pid" 2>/dev/null || true
    return 124  # Timeout exit code like GNU timeout
  else
    # Already finished, get exit code
    wait "$pid"
    return $?
  fi
}

# ============================================================================
# DOMAIN FUNCTIONS
# ============================================================================
# Provider selection
select_provider() {
  local quality="$1"
  local chain
  case "$quality" in
    high) chain="$QUALITY_HIGH" ;;
    medium) chain="$QUALITY_MEDIUM" ;;
    low) chain="$QUALITY_LOW" ;;
    *) return "$EXIT_INVALID_PARAMS" ;;
  esac

  local old_ifs="$IFS"
  IFS=' '
  for provider in $chain; do
    if [[ "${provider}" == "google" ]]; then
      # Google supports multiple auth methods: JSON credentials, gcloud, or API key
      if [[ -n "${GOOGLE_CREDENTIALS:-}" && -f "${GOOGLE_CREDENTIALS:-}" ]] || \
         command -v gcloud >/dev/null 2>&1 || \
         [[ -n "${GOOGLE_API_KEY:-}" && -n "${GOOGLE_PROJECT_ID:-}" ]]; then
        echo "$provider"
        IFS="$old_ifs"
        return 0
      fi
      continue
    fi
    local key_var="${provider^^}_API_KEY"
    if [[ "${provider}" == "replicate" ]]; then
      key_var="REPLICATE_API_TOKEN"
    fi
    if [[ -n "${!key_var:-}" ]]; then
      echo "$provider"
      IFS="$old_ifs"
      return 0
    fi
  done
  IFS="$old_ifs"

  log_err "No available provider for quality $quality"
  return "$EXIT_AUTH_FAILED"
}

# Get model used by provider
get_provider_model() {
  local provider="$1"
  case "$provider" in
    openai) echo "dall-e-3" ;;
    stability) echo "stable-diffusion-v1-6" ;;
    google) echo "imagen-4.0-generate-001" ;;
    huggingface) echo "${HF_MODEL:-stabilityai/stable-diffusion-2-1}" ;;
    bfl) echo "flux-1.1-pro" ;;
    replicate) echo "${REPLICATE_MODEL:-stability-ai/sdxl:39ed52f2a78e934b3ba6e2a89f5b1c712de7dfea535525255b1aa35c5565e08b}" ;;
    siliconflow) echo "stabilityai/stable-diffusion-3-medium" ;;
    *) echo "unknown" ;;
  esac
}

# Main image generation function
generate_image() {
  local prompt="$1"
  local negative_prompt="$2"
  local width="$3"
  local height="$4"
  local quality="$5"
  local output_path="$6"
  local provider="$7"
  local model="$8"

  # Determine provider if not provided
  if [[ -z "$provider" ]]; then
    provider="$(select_provider "$quality")"
    local exit_code=$?
    if (( exit_code != 0 )); then
      return "$exit_code"
    fi
  else
    # Validate provider
    case "$provider" in
      openai|stability|google|huggingface|bfl|replicate|siliconflow) ;;
      *) log_err "Invalid provider: $provider"; return "$EXIT_INVALID_PARAMS" ;;
    esac
  fi

  log_info "Using provider: $provider"

  # Determine model if not provided
  if [[ -z "$model" ]]; then
    model="$(get_provider_model "$provider")"
  fi

  # Compute cache key (include model)
  local cache_key
  cache_key="$(compute_cache_key "$prompt" "$negative_prompt" "$width" "$height" "$quality" "$provider" "$model")"

  # Check cache unless force is set
  if [[ "${FORCE}" != "true" ]]; then
    if cache_lookup "$cache_key" "$output_path"; then
      return "$EXIT_SUCCESS"
    fi
  fi

  # Generate image
  "generate_image_$provider" "$prompt" "$negative_prompt" "$width" "$height" "$quality" "$output_path" "$model"
  local exit_code=$?
  if (( exit_code == EXIT_AUTH_FAILED )); then
    provider_not_configured_error "$provider"
    return "$exit_code"
  elif (( exit_code != 0 )); then
    return "$exit_code"
  fi

  if [[ "${DRY_RUN}" == "true" ]]; then
    return "$exit_code"
  fi

  # Store in cache
  cache_store "$cache_key" "$output_path" "$prompt" "$negative_prompt" "$width" "$height" "$quality" "$provider" "$model"

  # Embed metadata if requested
  if [[ "${EMBED_METADATA}" == "true" ]]; then
    embed_metadata "$output_path" "${ARTIST}" "${COPYRIGHT}" "${KEYWORDS}" "${DESCRIPTION}" "$prompt" "$provider"
  fi

  # Optional cache cleanup
  cache_cleanup

  return "$EXIT_SUCCESS"
}

