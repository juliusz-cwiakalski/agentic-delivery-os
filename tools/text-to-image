# Show provider-specific error with documentation link
provider_not_configured_error() {
  local provider="$1"
  local anchor="${PROVIDER_DOC_ANCHORS[$provider]:-}"
  local doc_url="${DOC_BASE_URL}"
  [[ -n "$anchor" ]] && doc_url="${doc_url}#${anchor}"
