    while IFS='|' read -r provider model_id model_name description quality cost limits; do
      [[ -z "$provider" ]] && continue
      json_output+="{\"provider\":\"$provider\",\"model\":\"$model_id\",\"name\":\"$model_name\",\"description\":\"$description\",\"quality\":\"$quality\",\"cost\":\"$cost\",\"limitations\":\"$limits\"},"
    done <<< "$filtered_data"
    json_output="${json_output%,}]"
    echo "$json_output"
  else
    # ASCII table output
    echo "Available AI Image Generation Models"
    echo "====================================="
    if [[ "$all_models" != "true" && ${#available_providers[@]} -eq 0 ]]; then
      echo "No API keys detected. Use --all-models to see all available models."
      echo "Set environment variables for providers to see their models."
    fi
    echo ""
    
    # Print table header
    printf "%-12s | %-30s | %-8s | %-10s | %s\n" "Provider" "Model ID" "Quality" "Cost" "Description"
    printf "%s\n" "-------------------------------------------------------------------------------------------------------------------"
    
    while IFS='|' read -r provider model_id model_name description quality cost limits; do
      [[ -z "$provider" ]] && continue
      # Truncate description if too long
      local short_desc="${description:0:40}"
      [[ ${#description} -gt 40 ]] && short_desc="${short_desc}..."
      printf "%-12s | %-30s | %-8s | %-10s | %s\n" "$provider" "$model_id" "$quality" "$cost" "$short_desc"
    done <<< "$filtered_data"
    
    if [[ "$all_models" != "true" ]]; then
      echo ""
      echo "Available providers (with API keys): ${available_providers[*]:-none}"
      echo "Use --all-models to see all models across all providers."
    fi
  fi
  exit 0
}

# ============================================================================
# MAIN
# ============================================================================
main() {
  parse_args "$@"

  # Set defaults for optional variables to avoid nounset errors
  CONFIG_FILE="${CONFIG_FILE:-}"
  PARALLEL="${PARALLEL:-false}"
  FORCE="${FORCE:-false}"
  EMBED_METADATA="${EMBED_METADATA:-false}"
  MAX_PARALLEL="${MAX_PARALLEL:-}"
  ARTIST="${ARTIST:-}"
  COPYRIGHT="${COPYRIGHT:-}"
  KEYWORDS="${KEYWORDS:-}"
  DESCRIPTION="${DESCRIPTION:-}"
  OUTPUT_FORMAT="${OUTPUT_FORMAT:-text}"
  PROVIDER="${PROVIDER:-}"
  MODEL="${MODEL:-}"
  MODELS="${MODELS:-}"
  LIST_MODELS="${LIST_MODELS:-false}"
  ALL_MODELS="${ALL_MODELS:-false}"
  GOOGLE_CREDENTIALS="${GOOGLE_CREDENTIALS:-}"
  GOOGLE_LOCATION="${GOOGLE_LOCATION:-us-central1}"
  GOOGLE_AUTH_METHOD="${GOOGLE_AUTH_METHOD:-auto}"

  if [[ "$LIST_MODELS" == "true" ]]; then
    list_models "$ALL_MODELS"
    exit 0
  fi

  # Create directory structure
  ensure_directories

  # Ensure required commands
  require_cmd curl

  # Load .env if exists
  load_dotenv

  # Automatic version check (silent, non-blocking)
  _check_version

  # Merge config
  local config
  config="$(merge_config)"

  # Extract values
  local prompt output quality parallel max_parallel force embed_metadata artist copyright keywords description width height negative_prompt output_format provider model models
  eval "$config"

  # Set OUTPUT_FORMAT consistently
  OUTPUT_FORMAT="$output_format"

  # Check for batch mode: if config file has jobs array
  local is_batch=false
  if [[ -n "$CONFIG_FILE" ]]; then
    local yaml_content
    yaml_content="$(parse_yaml "$CONFIG_FILE")"
    if echo "$yaml_content" | _jq -e '.jobs' >/dev/null 2>&1; then
      is_batch=true
      log_info "Batch mode detected in $CONFIG_FILE"
    fi
  fi

  if [[ "$is_batch" == "true" ]]; then
    # Batch processing
    local yaml_content
    yaml_content="$(parse_yaml "$CONFIG_FILE")"
    local jobs
    jobs="$(echo "$yaml_content" | _jq '.jobs')"

    if [[ "$parallel" == "true" ]]; then
      process_batch_parallel "$jobs"
    else
      process_batch_sequential "$jobs"
    fi
    exit $?
  else
    # Single image generation
    # Validate config
    if ! validate_config "$prompt" "$output" "$quality" "$width" "$height"; then
      if [[ "$OUTPUT_FORMAT" == "json" ]]; then
        output_json_error "Validation failed" "$EXIT_INVALID_PARAMS"
      fi
      exit "$EXIT_INVALID_PARAMS"
    fi

    log_info "Configuration validated: prompt='$prompt', output='$output', quality='$quality', size=${width}x${height}"
    
    # Multiple models support
    if [[ -n "$models" ]]; then
      local model_list
      IFS=',' read -ra model_list <<< "$models"
      local results=()
      local success_count=0
      local failure_count=0
      
      for model_item in "${model_list[@]}"; do
        # Trim whitespace
        model_item="$(echo "$model_item" | xargs)"
        [[ -z "$model_item" ]] && continue
        
        # Generate output filename with model suffix
        local base="${output%.*}"
        local ext="${output##*.}"
        local model_output="${base}-${model_item}.${ext}"
        
        log_info "Generating image with model: $model_item"
        if generate_image "$prompt" "$negative_prompt" "$width" "$height" "$quality" "$model_output" "$provider" "$model_item"; then
          results+=("SUCCESS: $model_output")
          (( success_count++ ))
        else
          local exit_code=$?
          results+=("FAILED ($exit_code): $model_item")
          (( failure_count++ ))
        fi
      done
      
      # Summary
      log_info "Multiple model generation completed: $success_count succeeded, $failure_count failed"
      if [[ "$OUTPUT_FORMAT" == "json" ]]; then
        local json_results
        json_results="$(printf '%s\n' "${results[@]}" | _jq -R -s 'split("\n")[:-1] | map(split(": ")) | map({status: .[0], output: .[1]})' 2>/dev/null)"
        echo "{\"status\":\"partial\",\"summary\": {\"total\": ${#model_list[@]}, \"success\": $success_count, \"failure\": $failure_count}, \"results\": $json_results}"
      else
        printf '%s\n' "${results[@]}"
      fi
      
      if (( failure_count > 0 )); then
        exit "$EXIT_BATCH_PARTIAL_FAILURE"
      fi
    else
      # Single model generation
      if generate_image "$prompt" "$negative_prompt" "$width" "$height" "$quality" "$output" "$provider" "$model"; then
        log_info "Image generation completed successfully"
        if [[ "$OUTPUT_FORMAT" == "json" ]]; then
          echo "{\"status\":\"success\",\"output\":\"$output\"}"
        fi
      else
        local exit_code=$?
        log_err "Image generation failed"
        if [[ "$OUTPUT_FORMAT" == "json" ]]; then
          echo "{\"status\":\"error\",\"message\":\"Image generation failed\",\"exit_code\":$exit_code}"
        fi
        exit "$exit_code"
      fi
    fi
  fi
}

# Testable main guard
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
